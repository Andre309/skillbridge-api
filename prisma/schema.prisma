generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  mentee
  mentor
  both
  admin
}

enum SessionStatus {
  pending
  confirmed
  in_progress
  completed
  cancelled
  no_show
}

enum TransactionStatus {
  pending
  succeeded
  failed
  refunded
}

enum TransactionType {
  booking_payment
  mentor_payout
  platform_fee
  refund
}

enum SubscriptionPlan {
  starter
  pro
  business
}

enum ReportReason {
  inappropriate_behavior
  no_show
  misleading_profile
  technical_issue
  other
}

model User {
  id             String    @id @default(uuid())
  serialNumber  Int     @unique @default(autoincrement())
  email          String    @unique
  emailVerified  Boolean   @default(false) @map("email_verified")
  passwordHash   String?   @map("password_hash")
  fullName       String    @map("full_name")
  displayName    String?   @map("display_name")
  avatarUrl      String?   @map("avatar_url")
  role           UserRole  @default(mentee)
  timezone       String    @default("UTC")
  locale         String    @default("uk")
  bio            String?
  isActive       Boolean   @default(true) @map("is_active")
  isBanned       Boolean   @default(false) @map("is_banned")
  lastSeenAt     DateTime? @map("last_seen_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  oauthAccounts    OAuthAccount[]
  mentorProfile    MentorProfile?
  bookingsAsMentee Booking[]      @relation("MenteeBookings")
  reviewsGiven     Review[]       @relation("ReviewsGiven")
  reviewsReceived  Review[]       @relation("ReviewsReceived")
  messages         Message[]
  notifications    Notification[]
  favorites        Favorite[]
  transactions     Transaction[]
  reportsGiven     Report[]       @relation("ReportsGiven")
  reportsReceived  Report[]       @relation("ReportsReceived")

  @@map("users")
}

model OAuthAccount {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  provider    String
  providerUid String    @map("provider_uid")
  accessToken String?   @map("access_token")
  refreshToken String?  @map("refresh_token")
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUid])
  @@map("oauth_accounts")
}

model MentorProfile {
  id                  String           @id @default(uuid())
  userId              String           @unique @map("user_id")
  headline            String?
  yearsExperience     Int?             @map("years_experience")
  company             String?
  position            String?
  linkedinUrl         String?          @map("linkedin_url")
  githubUrl           String?          @map("github_url")
  websiteUrl          String?          @map("website_url")
  languages           String[]         @default([])
  isFeatured          Boolean          @default(false) @map("is_featured")
  isVerified          Boolean          @default(false) @map("is_verified")
  totalSessions       Int              @default(0) @map("total_sessions")
  avgRating           Decimal?         @db.Decimal(3, 2) @map("avg_rating")
  totalReviews        Int              @default(0) @map("total_reviews")
  totalEarnedCents    BigInt           @default(0) @map("total_earned_cents")
  stripeAccountId     String?          @map("stripe_account_id")
  subscriptionPlan    SubscriptionPlan @default(starter) @map("subscription_plan")
  subscriptionExpiresAt DateTime?      @map("subscription_expires_at")
  introVideoUrl       String?          @map("intro_video_url")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  user                  User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  services              Service[]
  bookings              Booking[]               @relation("MentorBookings")
  availabilityTemplates AvailabilityTemplate[]
  availabilityOverrides AvailabilityOverride[]
  subscriptions         Subscription[]
  favorites             Favorite[]

  @@map("mentor_profiles")
}

model Category {
  id        String     @id @default(uuid())
  parentId  String?    @map("parent_id")
  slug      String     @unique
  name      String
  icon      String?
  sortOrder Int        @default(0) @map("sort_order")
  isActive  Boolean    @default(true) @map("is_active")

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  services Service[]

  @@map("categories")
}

model Service {
  id                 String   @id @default(uuid())
  mentorId           String   @map("mentor_id")
  categoryId         String?  @map("category_id")
  title              String
  description        String?
  durationMinutes    Int      @map("duration_minutes")
  priceCents         Int      @map("price_cents")
  currency           String   @default("USD")
  maxBookingsPerDay  Int      @default(5) @map("max_bookings_per_day")
  isActive           Boolean  @default(true) @map("is_active")
  isTrial            Boolean  @default(false) @map("is_trial")
  trialLimitPerUser  Int?     @default(1) @map("trial_limit_per_user")
  tags               String[] @default([])
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  mentor   MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  category Category?     @relation(fields: [categoryId], references: [id])
  bookings Booking[]

  @@map("services")
}

model AvailabilityTemplate {
  id        String   @id @default(uuid())
  mentorId  String   @map("mentor_id")
  day       String   // monday..sunday
  startTime String   @map("start_time") // HH:mm
  endTime   String   @map("end_time")
  isActive  Boolean  @default(true) @map("is_active")

  mentor MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@unique([mentorId, day, startTime])
  @@map("availability_templates")
}

model AvailabilityOverride {
  id        String   @id @default(uuid())
  mentorId  String   @map("mentor_id")
  date      DateTime @db.Date
  startTime String?  @map("start_time")
  endTime   String?  @map("end_time")
  reason    String?

  mentor MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@map("availability_overrides")
}

model Booking {
  id                 String        @id @default(uuid())
  serviceId          String        @map("service_id")
  mentorId           String        @map("mentor_id")
  menteeId           String        @map("mentee_id")
  status             SessionStatus @default(pending)
  scheduledAt        DateTime      @map("scheduled_at")
  durationMinutes    Int           @map("duration_minutes")
  priceCents         Int           @map("price_cents")
  currency           String        @default("USD")
  platformFeePct     Decimal       @default(20.00) @db.Decimal(4, 2) @map("platform_fee_pct")
  platformFeeCents   Int           @default(0) @map("platform_fee_cents")
  mentorPayoutCents  Int           @default(0) @map("mentor_payout_cents")
  videoRoomId        String?       @map("video_room_id")
  videoRoomUrl       String?       @map("video_room_url")
  notes              String?
  cancellationReason String?       @map("cancellation_reason")
  cancelledBy        String?       @map("cancelled_by")
  cancelledAt        DateTime?     @map("cancelled_at")
  startedAt          DateTime?     @map("started_at")
  endedAt            DateTime?     @map("ended_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  service      Service       @relation(fields: [serviceId], references: [id])
  mentor       MentorProfile @relation("MentorBookings", fields: [mentorId], references: [id])
  mentee       User          @relation("MenteeBookings", fields: [menteeId], references: [id])
  review       Review?
  messages     Message[]
  transactions Transaction[]
  reports      Report[]

  @@map("bookings")
}

model Transaction {
  id              String            @id @default(uuid())
  bookingId       String?           @map("booking_id")
  userId          String            @map("user_id")
  type            TransactionType
  status          TransactionStatus @default(pending)
  amountCents     Int               @map("amount_cents")
  currency        String            @default("USD")
  stripePaymentId String?           @unique @map("stripe_payment_id")
  stripeTransferId String?          @map("stripe_transfer_id")
  stripeRefundId  String?           @map("stripe_refund_id")
  description     String?
  metadata        Json              @default("{}")
  failedReason    String?           @map("failed_reason")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  booking Booking? @relation(fields: [bookingId], references: [id])
  user    User     @relation(fields: [userId], references: [id])

  @@map("transactions")
}

model Review {
  id            String   @id @default(uuid())
  bookingId     String   @unique @map("booking_id")
  reviewerId    String   @map("reviewer_id")
  revieweeId    String   @map("reviewee_id")
  rating        Int
  comment       String?
  isPublic      Boolean  @default(true) @map("is_public")
  mentorReply   String?  @map("mentor_reply")
  mentorReplyAt DateTime? @map("mentor_reply_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewer User    @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee User    @relation("ReviewsReceived", fields: [revieweeId], references: [id])

  @@map("reviews")
}

model Message {
  id        String   @id @default(uuid())
  bookingId String   @map("booking_id")
  senderId  String   @map("sender_id")
  body      String
  isSystem  Boolean  @default(false) @map("is_system")
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender  User    @relation(fields: [senderId], references: [id])

  @@map("messages")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String
  title     String
  body      String?
  data      Json      @default("{}")
  readAt    DateTime? @map("read_at")
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Subscription {
  id                 String           @id @default(uuid())
  mentorId           String           @map("mentor_id")
  plan               SubscriptionPlan
  stripeSubId        String?          @unique @map("stripe_sub_id")
  stripeCustomerId   String?          @map("stripe_customer_id")
  status             String           @default("active")
  currentPeriodStart DateTime         @map("current_period_start")
  currentPeriodEnd   DateTime         @map("current_period_end")
  cancelledAt        DateTime?        @map("cancelled_at")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  mentor MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Report {
  id             String       @id @default(uuid())
  reporterId     String       @map("reporter_id")
  reportedId     String       @map("reported_id")
  bookingId      String?      @map("booking_id")
  reason         ReportReason
  description    String?
  isResolved     Boolean      @default(false) @map("is_resolved")
  resolvedBy     String?      @map("resolved_by")
  resolutionNote String?      @map("resolution_note")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  reporter User     @relation("ReportsGiven", fields: [reporterId], references: [id])
  reported User     @relation("ReportsReceived", fields: [reportedId], references: [id])
  booking  Booking? @relation(fields: [bookingId], references: [id])

  @@map("reports")
}

model Favorite {
  userId    String   @map("user_id")
  mentorId  String   @map("mentor_id")
  createdAt DateTime @default(now()) @map("created_at")

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  mentor MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  @@id([userId, mentorId])
  @@map("favorites")
}

model PromoCode {
  id             String    @id @default(uuid())
  code           String    @unique
  discountPct    Decimal?  @db.Decimal(5, 2) @map("discount_pct")
  discountCents  Int?      @map("discount_cents")
  maxUses        Int?      @map("max_uses")
  usedCount      Int       @default(0) @map("used_count")
  validFrom      DateTime  @default(now()) @map("valid_from")
  validUntil     DateTime? @map("valid_until")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@map("promo_codes")
}

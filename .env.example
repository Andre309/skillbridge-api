# Server
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/skillbridge

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=your_access_secret_32chars_minimum
JWT_REFRESH_SECRET=your_refresh_secret_32chars_minimum
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_CALLBACK_BASE_URL=http://localhost:4000/api/v1/auth

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PLATFORM_FEE_PCT=20

# Resend (Email)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@skillbridge.com

# Frontend
FRONTEND_URL=http://localhost:3000

# AWS S3 / Cloudflare R2
S3_BUCKET=skillbridge-uploads
S3_REGION=eu-central-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Video (Daily.co)
DAILY_API_KEY=
DAILY_DOMAIN=skillbridge.daily.co
